# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/cme_data
DB_HOST=localhost
DB_PORT=5433
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=cme_data
DB_MIN_POOL=2
DB_MAX_POOL=10

# Browser & Scraper Configuration
HEADLESS=true
PROXY_URL=
USER_AGENT=random
MAX_BROWSER_INSTANCES=2
REQUEST_DELAY_MIN=1500
REQUEST_DELAY_MAX=2500

# Output & Retention
OUTPUT_DIR=./output
KEEP_DAYS=90

# Forward-test contract overrides (optional)
# Example: ACTIVE_CONTRACT_GC=GCQ6
ACTIVE_CONTRACT_ES=
ACTIVE_CONTRACT_NQ=
ACTIVE_CONTRACT_GC=

# Notifications
SLACK_WEBHOOK_URL=
LINE_NOTIFY_TOKEN=
NOTIFY_ON_SUCCESS=true
NOTIFY_ON_FAILURE=true

# Scheduler Timezone
TIMEZONE=America/Chicago
SCHEDULER_TIMEZONE=Asia/Bangkok

# Analysis Hourly Job
ANALYSIS_ENABLED=true
ANALYSIS_CRON=0 17-23,0-15 * * 1-5
ANALYSIS_SYMBOLS=ES,NQ,GC
ANALYSIS_TIMEFRAMES=1m
ANALYSIS_FETCH_OI=true

# CME Account Credentials
CME_EMAIL=
CME_PASSWORD=
